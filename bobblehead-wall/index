<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Webex Ballpark — Recent Players</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;background:#0a1526;overflow:hidden}
  /* The whole page is the background image at its native 1537x1023 ratio,
     letterboxed to fit any screen. The four slots are positioned as
     percentages of that image, so they always land on the orange boxes. */
  #stage{position:fixed;inset:0;display:flex;align-items:center;justify-content:center}
  #board{position:relative;aspect-ratio:1537 / 1023;
    max-width:100vw;max-height:100vh;width:auto;height:auto;
    background:url('bg.png') center/contain no-repeat}
  /* a slot sits exactly over each orange rectangle */
  .slot{position:absolute;display:flex;align-items:center;justify-content:center;
    overflow:hidden;border-radius:14px}
  /* the image is centered and scaled to fit inside the box without distortion */
  .slot img{max-width:94%;max-height:94%;width:auto;height:auto;object-fit:contain;
    border-radius:8px;
    animation:fadeIn .6s ease both}
  @keyframes fadeIn{from{opacity:0;transform:scale(.92)}to{opacity:1;transform:scale(1)}}

  /* slot positions measured from the background (percentages of the board) */
  #slot0{left:3.90%;  top:22.19%; width:21.99%; height:59.34%}
  #slot1{left:25.89%; top:22.19%; width:23.23%; height:59.34%}
  #slot2{left:49.12%; top:22.19%; width:23.03%; height:59.34%}
  #slot3{left:73.65%; top:22.19%; width:22.19%; height:59.34%}
</style>
</head>
<body>
<div id="stage">
  <div id="board">
    <div class="slot" id="slot0"></div>
    <div class="slot" id="slot1"></div>
    <div class="slot" id="slot2"></div>
    <div class="slot" id="slot3"></div>
  </div>
</div>

<script>
/* ============================================================
   EDIT THIS LIST — paste your bobblehead image filenames here.
   They live in the  bobbles/  subfolder next to this file.
   Include the file extension (.jpg or .jpeg), exactly as named.
   ============================================================ */
const IMAGES = [
  "Image_June_7_2026_1_09_AM.jpeg",
  "Image_June_7_2026_1_15_AM.jpeg",
  "Image_June_7_2026_1_22_AM.jpeg",
  "Image_June_7_2026_1_30_AM.jpeg",
  // add as many as you like — if more than 4, the board rotates through them
];

const FOLDER = "bobbles/";       // subfolder holding the images
const ROTATE_SECONDS = 8;        // if you have >4 images, how often a slot swaps
const ORDER = "random";          // "random" = shuffle the lineup
                                 // "newest" = last entries in IMAGES first
                                 // "listed" = exactly the order above
/* ============================================================ */

const slots = [0,1,2,3].map(i=>document.getElementById("slot"+i));

function shuffle(arr){
  const a=[...arr];
  for(let i=a.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; }
  return a;
}

// build the pool based on the chosen ORDER
let pool;
if(ORDER === "random")      pool = shuffle(IMAGES);
else if(ORDER === "newest") pool = [...IMAGES].reverse();
else                        pool = [...IMAGES];

function setSlot(slotEl, file){
  const img = document.createElement("img");
  img.src = FOLDER + file;
  img.alt = "Bobblehead";
  img.onerror = ()=>{ img.remove(); };   // silently skip a missing/misnamed file
  slotEl.innerHTML = "";
  slotEl.appendChild(img);
}

// place the first up-to-4 images
function fillInitial(){
  for(let i=0;i<4;i++){
    if(pool[i]) setSlot(slots[i], pool[i]);
  }
}

fillInitial();

// If there are more than 4 images, gently rotate them through the slots.
if(pool.length > 4){
  let nextIdx = 4;                      // next image (used for newest/listed order)
  let slotCursor = 0;                   // which slot to replace next
  setInterval(()=>{
    let file;
    if(ORDER === "random"){
      // show ones not currently on screen, picked at random
      const onScreen = slots.map(s=> s.querySelector("img")?.getAttribute("src"));
      const candidates = pool.filter(f=> !onScreen.includes(FOLDER + f));
      const fromList = candidates.length ? candidates : pool;
      file = fromList[Math.floor(Math.random()*fromList.length)];
    } else {
      file = pool[nextIdx % pool.length];
      nextIdx = (nextIdx + 1) % pool.length;
    }
    setSlot(slots[slotCursor], file);
    slotCursor = (slotCursor + 1) % 4;
  }, ROTATE_SECONDS * 1000);
}
</script>
</body>
</html>
